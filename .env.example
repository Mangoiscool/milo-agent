# Milo Agent Configuration
# 复制此文件为 .env 并填入实际值

# ====================
# 应用配置
# ====================
APP_NAME=milo-agent
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(levelname)s - %(name)s - %(message)s

# ====================
# LLM 提供者配置
# ====================
# 选择默认的 LLM 提供者
# 选项: ollama, qwen, glm, deepseek
DEFAULT_PROVIDER=ollama

# Qwen (通义千问)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.5-flash

# GLM (智谱)
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4.7-flash

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Ollama (本地)
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_THINK=false

# ====================
# Agent 配置
# ====================
MAX_MEMORY_MESSAGES=50
ENABLE_STREAM_FALLBACK=true
AUTO_SAVE=true
USE_INTELLIGENT_PRUNING=false

# ====================
# 工具配置
# ====================
# 工具执行重试配置
TOOL_MAX_RETRIES=3
TOOL_INITIAL_DELAY=1.0
TOOL_MAX_DELAY=30.0

# ====================
# Web UI 配置
# ====================
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8000
WEBUI_RELOAD=true

# ====================
# 日志配置
# ====================
# 日志文件路径（可选）
LOG_FILE=
# 使用结构化日志（JSON 格式）
USE_STRUCTURED_LOGGING=false

# ====================
# 存储配置
# ====================
# Workspace 目录（用于项目数据存储，默认：项目根目录/workspace）
# 示例: WORKSPACE_DIR=/path/to/your/workspace
WORKSPACE_DIR=workspace

# ====================
# 搜索配置
# ====================
# Tavily API Key（用于网络搜索）
TAVILY_API_KEY=
